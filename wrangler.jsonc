{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "myfitnesspal-mcp-kacper",
  "main": "worker/index.ts",
  "compatibility_date": "2026-06-23",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "containers": [
    {
      "class_name": "MyFitnessPalContainer",
      "image": "ghcr.io/kacpherek/myfitnesspal-mcp-cloudflare:latest",
      "max_instances": 1
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "class_name": "MyFitnessPalContainer",
        "name": "MFP_CONTAINER"
      }
    ]
  },
  "migrations": [
    {
      "new_sqlite_classes": ["MyFitnessPalContainer"],
      "tag": "v1"
    }
  ]
}

